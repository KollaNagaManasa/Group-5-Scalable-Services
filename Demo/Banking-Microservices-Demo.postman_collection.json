    {
      "name": "3. Transaction Service",
      "item": [
        {
          "name": "Create Second Account (for transfer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"accountNumber\": \"ACC-2026-5002\",\n  \"accountType\": \"CHECKING\",\n  \"currency\": \"INR\",\n  \"initialBalance\": 30000\n}"
            },
            "url": {
              "raw": "http://localhost:8082/accounts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["accounts"]
            }
          }
        },
        {
          "name": "Transfer Money (Inter-Service)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "txn-2026-001"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountNumber\": \"ACC-2026-5001\",\n  \"toAccountNumber\": \"ACC-2026-5002\",\n  \"amount\": 5000,\n  \"reason\": \"Payment for services\"\n}"
            },
            "url": {
              "raw": "http://localhost:8083/transactions/transfer",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["transactions", "transfer"]
            }
          }
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["transactions"]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/transactions/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["transactions", "1"]
            }
          }
        },
        {
          "name": "Get Account Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/transactions/account/ACC-2026-5001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["transactions", "account", "ACC-2026-5001"]
            }
          }
        },
        {
          "name": "Error - Insufficient Funds",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "txn-2026-error-001"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountNumber\": \"ACC-2026-5001\",\n  \"toAccountNumber\": \"ACC-2026-5002\",\n  \"amount\": 500000,\n  \"reason\": \"This should fail - insufficient balance\"\n}"
            },
            "url": {
              "raw": "http://localhost:8083/transactions/transfer",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["transactions", "transfer"]
            }
          }
        },
