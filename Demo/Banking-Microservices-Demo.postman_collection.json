  "item": [
    {
      "name": "1. Customer Service",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rashi Verma\",\n  \"email\": \"rashi@bank.com\",\n  \"phone\": \"+91-9876543210\",\n  \"kycStatus\": \"VERIFIED\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/customers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["customers"]
            }
          }
        },
        {
          "name": "Get All Customers",
